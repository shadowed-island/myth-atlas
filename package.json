{
  "name": "myth-atlas",
  "version": "0.1.5",
  "description": "Explore mythology and folklore on a luminous 3D globe.",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "stories:sync": "node scripts/sync-story-content.mjs",
    "readme:stories": "pnpm stories:sync",
    "pages:stories": "pnpm stories:sync",
    "desktop:build": "pnpm run electron:build && cross-env BUILD_TARGET=desktop next build",
    "desktop:dev": "node scripts/desktop-dev.mjs",
    "desktop:dist": "pnpm run desktop:build && node scripts/desktop-dist.mjs",
    "desktop:dist:mac:arm64": "pnpm run desktop:build && node scripts/desktop-dist.mjs --mac zip --arm64",
    "desktop:dist:win:x64": "pnpm run desktop:build && node scripts/desktop-dist.mjs --win nsis zip --x64",
    "desktop:preview": "pnpm run desktop:build && cross-env MYTH_ATLAS_FORCE_PROD=1 MYTH_ATLAS_DESKTOP_DIST_DIR=out electron .electron-build/electron/main.js",
    "desktop:smoke": "pnpm run desktop:build && node tests/electron/run-smoke.mjs",
    "electron:build": "tsc -p tsconfig.electron.json",
    "release:sync-version": "node scripts/sync-version-from-tag.mjs",
    "start": "next start",
    "e2e": "node tests/e2e/run-e2e.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "d3-geo": "^3.1.1",
    "lucide-react": "^0.555.0",
    "next": "^16.0.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.181.2",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/d3-geo": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "cross-env": "^10.1.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "playwright-core": "^1.59.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
